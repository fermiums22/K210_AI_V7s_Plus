# Прошивки и модели — тяжёлые бинарники, в git не храним
/firmware/*.bin
/firmware/**/*.kmodel
/firmware/**/*.smodel

# Локально скачанные инсталляторы/архивы (драйвер, kflash_gui, IDE)
/downloads/

# Вложенный SDK (скачан локально — не субмодуль, исключаем)
/firmware/sdk-freertos/

# Сборка C/SDK (если появится)
/build/
*.o
*.elf
*.map

# Секреты: Wi-Fi креды живут только на плате в /flash/wifi.json, не в git
wifi.json
**/wifi.json

# Системное
Thumbs.db
.DS_Store

# Python cache
__pycache__/
*.pyc
